---
import type { CollectionEntry } from 'astro:content';
import CategoryBadge from './CategoryBadge.astro';
import { makeExcerpt, formatDate } from '../lib/posts';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const excerpt = makeExcerpt(post, post.body ?? '');
const dateStr = formatDate(post.data.date);
---

<article class="post-card">
  <div class="post-card-meta">
    <CategoryBadge category={post.data.category} />
    <time datetime={post.data.date.toISOString()}>{dateStr}</time>
  </div>
  <h2 class="post-card-title">
    <a href={`/posts/${post.id}/`}>{post.data.title}</a>
  </h2>
  <p class="post-card-excerpt">{excerpt}</p>
</article>

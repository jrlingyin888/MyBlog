---
import { getCollection } from 'astro:content';
import { getPublishedPosts, getPostsByTag, getAllTags } from '../../lib/posts';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';

export async function getStaticPaths() {
  const posts = getPublishedPosts(await getCollection('posts'));
  return getAllTags(posts).map((tag) => ({ params: { tag }, props: { tag } }));
}

const { tag } = Astro.props;
const posts = getPostsByTag(
  getPublishedPosts(await getCollection('posts')),
  tag,
);
---

<BaseLayout title={`#${tag}`}>
  <h1 class="page-title">#{tag}</h1>
  <section class="card-grid">
    {posts.map((post) => <PostCard post={post} />)}
  </section>
</BaseLayout>
